# ──────────────────────────────────────────────────────────────────────────────
# Kopieer dit bestand naar .env.local en vul alle waarden in.
# .env.local staat in .gitignore en wordt nooit naar git gepusht.
# ──────────────────────────────────────────────────────────────────────────────

# ── Odoo-verbinding ────────────────────────────────────────────────────────────
# Volledig adres van de Odoo-instantie (geen trailing slash)
ODOO_URL=https://jouwbedrijf.odoo.com

# Naam van de Odoo-database
ODOO_DB=jouwbedrijf

# E-mailadres van de API-gebruiker in Odoo
ODOO_USERNAME=api@jouwbedrijf.be

# API-sleutel: aanmaken via Odoo → Instellingen → Gebruikers → API-sleutels
ODOO_API_KEY=HIER_JOUW_API_SLEUTEL_PLAKKEN

# ── Beveiliging ────────────────────────────────────────────────────────────────
# Willekeurige string, minimaal 32 tekens. Genereer met: openssl rand -base64 48
JWT_SECRET=vervang_dit_door_een_lange_willekeurige_string_min32tekens

# ── Odoo locaties en picking ───────────────────────────────────────────────────
# Vind deze IDs in Odoo met debug-modus (?debug=1 in de URL):

# ID van het bewerkingstype (bijv. "Interne overboekingen")
# Odoo → Voorraadbeheer → Configuratie → Bewerkingstypes → kijk in de URL
ODOO_PICKING_TYPE_ID=7

# ID van de bronlocatie (magazijn van waaruit gepickt wordt)
# Odoo → Voorraadbeheer → Configuratie → Locaties → open bronlocatie → kijk in URL
ODOO_SOURCE_LOCATION_ID=17

# ID van de bestemmingslocatie (techniekerbus of picklocatie)
# Odoo → Voorraadbeheer → Configuratie → Locaties → open bestemmingslocatie → kijk in URL
ODOO_DEST_LOCATION_ID=13

# ID van de bovenliggende magazijnlocatie voor het stockoverzicht (beheerders)
# Dit is typisch de "WH"-locatie die alle sub-locaties omvat
# Odoo → Voorraadbeheer → Configuratie → Locaties → open "WH" → kijk in URL
ODOO_WAREHOUSE_LOCATION_ID=5

# ── Supabase (database) ────────────────────────────────────────────────────────
# Supabase dashboard → Project Settings → API

# Project URL (eindigt op .supabase.co)
SUPABASE_URL=https://xyzxyzxyz.supabase.co

# Service role key (geheim houden! nooit in de browser)
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Frontend (optioneel) ───────────────────────────────────────────────────────
# API-adres voor lokale ontwikkeling (verwijder of overschrijf op productie)
REACT_APP_API_BASE=http://localhost:3001

# Naam en ondertitel bovenaan de sidebar (standaardwaarden indien weggelaten)
REACT_APP_COMPANY_NAME=Telcom
REACT_APP_COMPANY_SUBTITLE=Bestelportaal
